# ============================================================
# Indian Stock Market Financial Agent - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Provider (Choose ONE) ---
# Option 1: OpenAI (GPT-3.5-turbo recommended for cost)
OPENAI_API_KEY=your_openai_api_key_here

# Option 2: Google Gemini (Free tier available)
GOOGLE_API_KEY=your_google_api_key_here

# --- Active LLM Provider ---
# Options: "openai" or "gemini"
LLM_PROVIDER=

# --- News API ---
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=

# --- Alpha Vantage (Optional - for additional stock data) ---
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# --- App Settings ---
APP_TITLE=Indian Stock Market Financial Agent
DEBUG=False
